rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isValidString(text, maxLength) {
      return text is string && text.size() > 0 && text.size() <= maxLength;
    }
    
    function isRecentTimestamp(ts) {
      // Convert request.time to milliseconds and compare with client timestamp
      // Allow timestamps within 5 minutes (to account for clock skew)
      let now = request.time.toMillis();
      return ts > now - 300000 && ts < now + 300000;
    }
    
    // Rate limiting helper (basic - prevents spam)
    function hasNotExceededRateLimit(path) {
      // Allow max 10 operations per minute per client
      return request.time > resource.data.lastUpdated + duration.value(6, 's');
    }
    
    // ==================== GLOBAL STATISTICS ====================
    // Read: Everyone can read global stats
    // Write: Only through Cloud Functions (admin) or rate-limited increments
    match /globals/statistics {
      allow read: if true;
      
      // Allow anonymous writes with rate limiting
      allow update: if request.auth == null 
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['totalWishes', 'totalDiyas', 'totalDonations', 'donationCount', 'lastUpdated'])
        && request.resource.data.totalWishes >= resource.data.totalWishes
        && request.resource.data.totalDiyas >= resource.data.totalDiyas;
      
      allow create: if false; // Only admin can create
      allow delete: if false;
    }
    
    // ==================== PRESENCE TRACKING ====================
    // Track online devotees (read-only for users, auto-created)
    match /presence/{deviceId} {
      allow read: if true;
      
      // Allow updates from any device for their own presence
      allow create, update: if request.auth == null
        && isValidString(request.resource.data.deviceId, 100)
        && request.resource.data.timestamp is number
        && isRecentTimestamp(request.resource.data.timestamp);
      
      allow delete: if false; // Auto-cleanup via Cloud Function
    }
    
    // ==================== COMMUNITY PRAYER WALL ====================
    // Anonymous wishes shared for collective prayers
    match /communityWishes/{wishId} {
      allow read: if true;
      
      // Allow anonymous wish creation with validation
      allow create: if request.auth == null
        && isValidString(request.resource.data.title, 100)
        && isValidString(request.resource.data.category, 50)
        && isValidString(request.resource.data.deityId, 50)
        && request.resource.data.isAnonymous == true
        && request.resource.data.timestamp is number
        && isRecentTimestamp(request.resource.data.timestamp)
        && request.resource.data.prayerCount == 0;
      
      // Allow prayer count increment only
      allow update: if request.auth == null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayerCount'])
        && request.resource.data.prayerCount == resource.data.prayerCount + 1;
      
      allow delete: if false; // Auto-cleanup via Cloud Function
    }
    
    // ==================== GLOBAL DIYAS ====================
    // Diyas lit by devotees worldwide
    match /diyas/{diyaId} {
      allow read: if true;
      
      // Allow anonymous diya lighting
      allow create: if request.auth == null
        && isValidString(request.resource.data.name, 20)
        && isValidString(request.resource.data.deityId, 50)
        && request.resource.data.timestamp is number
        && isRecentTimestamp(request.resource.data.timestamp);
      
      allow update, delete: if false;
    }
    
    // ==================== TEMPLE ANNOUNCEMENTS ====================
    // Read-only for devotees, managed by admin
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if false; // Only admin/Cloud Functions
    }
    
    // ==================== TEMPLE EVENTS ====================
    // Read-only for devotees, managed by admin
    match /events/{eventId} {
      allow read: if true;
      allow write: if false; // Only admin/Cloud Functions
    }
    
    // ==================== DONATIONS ====================
    // Anonymous donation tracking for transparency
    match /donations/{donationId} {
      allow read: if true; // Public transparency
      
      // Allow anonymous donation logging
      allow create: if request.auth == null
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 100000 // Max 1 lakh per transaction
        && isValidString(request.resource.data.purpose, 100)
        && request.resource.data.isAnonymous == true
        && request.resource.data.timestamp is number
        && isRecentTimestamp(request.resource.data.timestamp);
      
      allow update, delete: if false;
    }
    
    // ==================== DEFAULT - DENY ALL ====================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
