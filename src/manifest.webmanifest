{
  "name": "E-Darshan Mandir",
  "short_name": "KH E-Mandir",
  "description": "Virtual Hanuman Temple - A devotional progressive web application",
  "theme_color": "#f97316",
  "background_color": "#fff7ed",
  "display": "standalone",
  "scope": "/",
  "start_url": "/",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "assets/icons/source/temple-icon.svg",
