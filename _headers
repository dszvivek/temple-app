# Cache static assets for 1 year (with immutable flag)
/assets/**
  Cache-Control: public, max-age=31536000, immutable

# Never cache the main HTML file - always get fresh version
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Never cache the service worker - always get latest
/ngsw-worker.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Never cache the service worker config
/ngsw.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# JavaScript and CSS files - short cache (5 minutes) to allow quick updates
/*.js
  Cache-Control: public, max-age=300, must-revalidate

/*.css
  Cache-Control: public, max-age=300, must-revalidate

# Manifest file - short cache
/manifest.webmanifest
  Cache-Control: public, max-age=3600, must-revalidate
